# Surface Bridge Configuration
THRUNT_BRIDGE_PORT=7483
THRUNT_BRIDGE_HOST=127.0.0.1

# Path to the project root containing .planning/
THRUNT_PROJECT_ROOT=.

# Enable mock mode (no real .planning/ required)
THRUNT_MOCK_MODE=false

# Comma-separated browser extension IDs allowed to authenticate from extension origins
THRUNT_ALLOWED_EXTENSION_IDS=

# Override planning directory name
# THRUNT_PLANNING_DIR=.planning
