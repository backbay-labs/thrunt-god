{
  "name": "@thrunt-surfaces/site-adapters",
  "version": "0.1.0",
  "description": "Site adapter implementations for vendor console extraction",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./registry": "./src/registry.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "certify": "bun run ./scripts/certify.ts"
  },
  "dependencies": {
    "@thrunt-surfaces/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "^1.54.2",
    "typescript": "^5.7.0"
  }
}
