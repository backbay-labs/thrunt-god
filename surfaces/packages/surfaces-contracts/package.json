{
  "name": "@thrunt-surfaces/contracts",
  "version": "0.1.0",
  "description": "Shared type contracts for THRUNT multi-surface workspace",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
