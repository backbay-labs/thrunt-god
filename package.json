{
  "name": "thrunt-god",
  "version": "0.1.0",
  "description": "Threat-hunting orchestration system for Claude Code, OpenCode, Gemini, Codex, Copilot, Cursor, and Windsurf.",
  "bin": {
    "thrunt-god": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "thrunt-god",
    "agents",
    "hooks/dist",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "threat-hunting",
    "cybersecurity",
    "incident-response",
    "detection-engineering",
    "telemetry",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli",
    "thrunt"
  ],
  "author": "TÂCHES",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/backbay-labs/thrunt-god"
  },
  "homepage": "https://github.com/backbay-labs/thrunt-god#readme",
  "bugs": {
    "url": "https://github.com/backbay-labs/thrunt-god/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "build:hooks": "node scripts/build-hooks.js",
    "build:vscode": "npm --prefix apps/vscode run build",
    "lint:vscode": "npm --prefix apps/vscode run lint",
    "prepublishOnly": "npm run build:hooks",
    "test": "node scripts/run-tests.cjs",
    "test:vscode": "npm --prefix apps/vscode test",
    "test:vscode:unit": "npm --prefix apps/vscode run test:unit",
    "test:vscode:smoke": "npm --prefix apps/vscode run test:smoke",
    "test:vscode:dogfood": "npm --prefix apps/vscode run test:dogfood",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --include 'thrunt-god/bin/lib/**/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs",
    "test:integration:up": "docker compose -f tests/integration/docker-compose.yml up -d --wait",
    "test:integration:down": "docker compose -f tests/integration/docker-compose.yml down -v",
    "test:integration": "npm run test:integration:up && node scripts/run-integration-tests.cjs; EXIT=$?; npm run test:integration:down; exit $EXIT"
  }
}
