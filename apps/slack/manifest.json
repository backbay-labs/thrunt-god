{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "THRUNT",
    "description": "Threat hunting coordination bot — status, findings, receipts, and case management",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "THRUNT",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "Create THRUNT Case",
        "type": "message",
        "callback_id": "create_thrunt_case",
        "description": "Create THRUNT Case"
      }
    ],
    "slash_commands": [
      {
        "command": "/hunt",
        "description": "THRUNT hunt operations — status, findings, receipts, case",
        "usage_hint": "[status | findings | receipts | case <title> | help]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "commands",
        "channels:history",
        "groups:history",
        "im:history",
        "mpim:history",
        "chat:write.public"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true
  }
}
