{
  "name": "thrunt-god",
  "displayName": "THRUNT God",
  "description": "Hunt investigation dashboard for THRUNT God threat-hunting framework",
  "version": "0.1.0",
  "publisher": "backbay-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/backbay-labs/thrunt-god"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.hunt/MISSION.md",
    "workspaceContains:.planning/MISSION.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "thruntGodSidebar",
          "title": "THRUNT God",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "thruntGodSidebar": [
        {
          "id": "thruntGod.huntTree",
          "name": "Investigation",
          "when": "thruntGod.huntDetected"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "thruntGod.huntTree",
        "contents": "No hunt detected in this workspace.\n\nOpen a folder containing .planning/MISSION.md or .hunt/MISSION.md to get started.\n[Open Folder](command:vscode.openFolder)",
        "when": "!thruntGod.huntDetected"
      }
    ],
    "commands": [
      {
        "command": "thrunt-god.showInfo",
        "title": "THRUNT: Show Extension Info"
      },
      {
        "command": "thrunt-god.openArtifact",
        "title": "THRUNT: Open Artifact"
      },
      {
        "command": "thrunt-god.revealInExplorer",
        "title": "THRUNT: Reveal in Explorer"
      },
      {
        "command": "thrunt-god.copyPath",
        "title": "THRUNT: Copy Path"
      },
      {
        "command": "thrunt-god.refreshSidebar",
        "title": "THRUNT: Refresh Sidebar",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "thrunt-god.openArtifact",
          "when": "view == thruntGod.huntTree",
          "group": "navigation"
        },
        {
          "command": "thrunt-god.revealInExplorer",
          "when": "view == thruntGod.huntTree",
          "group": "navigation"
        },
        {
          "command": "thrunt-god.copyPath",
          "when": "view == thruntGod.huntTree",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "thrunt-god.refreshSidebar",
          "when": "view == thruntGod.huntTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:production": "NODE_ENV=production node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit",
    "prepackage": "npm run build:production",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "node --require ./test/_setup/vscode-mock.cjs --test test/unit/**/*.test.cjs",
    "test:smoke": "node test/smoke.cjs",
    "test:integration": "vscode-test",
    "pretest:unit": "npm run build",
    "pretest:smoke": "npm run build"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "esbuild-register": "^3.6.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm-table": "^2.0.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm-table": "^2.1.1"
  }
}
